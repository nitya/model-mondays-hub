{
  "name": "model-mondays-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Data-first, agent-first knowledge base for the Model Mondays livestream series.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "validate": "node scripts/validate.mjs",
