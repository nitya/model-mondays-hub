---
// site/src/pages/index.astro
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";

const base = import.meta.env.BASE_URL;
const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
const formatCompact = (value: number) =>
  new Intl.NumberFormat("en-US", { notation: "compact", maximumFractionDigits: 1 }).format(value);
const getEpisodeLabel = (seasonNumber: number | undefined, episodeId: string) => {
  const match = episodeId.match(/s\d+-e(\d+)/i);
  const episodeNumber = match ? Number(match[1]) : undefined;
  if (seasonNumber == null || episodeNumber == null) return undefined;
  return `S${seasonNumber} · E${episodeNumber}`;
};

const episodes = (await getCollection("episodes")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const published = episodes.filter((e) => e.data.status === "published");
const upcoming = episodes.filter((e) => e.data.status !== "published").slice(0, 4);
const latest = published.slice(0, 3);

const seasons = await getCollection("seasons");
const seasonById = new Map(seasons.map((season) => [season.id, season.data]));
const activeSeason = seasons.find((s) => s.data.status === "upcoming") ?? seasons[0];

const totalViews = published.reduce((sum, ep) => sum + (ep.data.metrics?.views ?? 0), 0);
const totalLikes = published.reduce((sum, ep) => sum + (ep.data.metrics?.likes ?? 0), 0);
const totalComments = published.reduce((sum, ep) => sum + (ep.data.metrics?.comments ?? 0), 0);

const stats = [
  { label: "Seasons", value: seasons.length.toLocaleString("en-US") },
  { label: "Published Episodes", value: published.length.toLocaleString("en-US") },
  { label: "Total Views", value: formatCompact(totalViews) },
  { label: "Total Likes", value: formatCompact(totalLikes) },
  { label: "Total Comments", value: formatCompact(totalComments) },
];

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const latestPost = posts[0];
---

<BaseLayout title="Home">
  <section class="hero">
    <p class="pill pill--technology">Weekly since 2025</p>
    <h1>Build your Model IQ, one Monday at a time.</h1>
    <p class="muted hero__lede">
      Model Mondays is Microsoft's weekly AI livestream/podcast series — Tech
      Spotlights, Customer Stories, Study Corner, and Partner Spotlights
      across the Microsoft Foundry model catalog.
      {activeSeason && (
        <>
          {" "}<strong>{activeSeason.data.title}</strong> kicks off{" "}
          {activeSeason.data.startDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}.
        </>
      )}
    </p>
    <div class="hero__actions">
      <a class="button" href={`${base}episodes/`}>Browse episodes</a>
      <a class="button button--ghost" href={`${base}speakers/`}>Meet the speakers</a>
    </div>
  </section>

  <section class="stats-bar section" aria-label="Model Mondays stats">
    {stats.map((stat) => (
      <div class="stat-card">
        <strong class="stat-card__value">{stat.value}</strong>
        <span class="stat-card__label muted">{stat.label}</span>
      </div>
    ))}
  </section>

  {latestPost && (
    <section class="section">
      <h2>Latest from the blog</h2>
      <a class="card" href={`${base}blog/${latestPost.id}/`}>
        <h3>{latestPost.data.title}</h3>
        {latestPost.data.summary && <p class="muted">{latestPost.data.summary}</p>}
      </a>
    </section>
  )}

  <section class="section">
    <h2>Latest episodes</h2>
    <div class="grid">
      {latest.map((ep) => (
        <Card
          href={`${base}episodes/${ep.id}/`}
          title={ep.data.title}
          publishDate={formatDate(ep.data.publishDate)}
          videoId={ep.data.youtubeVideoId}
          seasonLabel={getEpisodeLabel(seasonById.get(ep.data.season)?.number, ep.id)}
          views={ep.data.metrics?.views}
        />
      ))}
    </div>
  </section>

  {upcoming.length > 0 && (
    <section class="section">
      <h2>Coming up in {activeSeason?.data.title ?? "the next season"}</h2>
      <div class="grid">
        {upcoming.map((ep) => (
          <Card
            href={`${base}episodes/${ep.id}/`}
            title={ep.data.title}
            subtitle={ep.data.status !== "published" ? "Upcoming" : undefined}
            publishDate={formatDate(ep.data.publishDate)}
            videoId={ep.data.youtubeVideoId}
            seasonLabel={getEpisodeLabel(seasonById.get(ep.data.season)?.number, ep.id)}
            views={ep.data.metrics?.views}
          />
        ))}
      </div>
    </section>
  )}

  <style>
    .hero {
      padding: 3rem 0 1.5rem;
      max-width: 720px;
      position: relative;
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      margin: 0.75rem 0;
      background: var(--mm-accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero__lede {
      font-size: 1.1rem;
      line-height: 1.7;
    }
    .hero__actions {
      display: flex;
      gap: 0.75rem;
      margin-top: 1.5rem;
      flex-wrap: wrap;
    }
    .button--ghost {
      background: transparent;
      color: var(--mm-text);
      border: 1.5px solid var(--mm-border);
      box-shadow: none;
    }
    .button--ghost:hover {
      border-color: var(--mm-accent);
      color: var(--mm-accent);
      background: var(--mm-accent-soft);
      box-shadow: var(--mm-shadow-sm);
    }
    .section { margin-top: 3rem; }
    .section h2 { margin-bottom: 1.25rem; }
  </style>
</BaseLayout>
