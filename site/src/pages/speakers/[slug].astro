---
// site/src/pages/speakers/[slug].astro
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";

export async function getStaticPaths() {
  const speakers = await getCollection("speakers");
  return speakers.map((s) => ({ params: { slug: s.id }, props: { speaker: s } }));
}

const { speaker } = Astro.props;
const base = import.meta.env.BASE_URL;

const allEpisodes = await getCollection("episodes");
const episodes = allEpisodes
  .filter((ep) => ep.data.speakers.includes(speaker.id))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title={speaker.data.name} description={speaker.data.bio}>
  <a href={`${base}speakers/`} class="muted">&larr; All speakers</a>
  <h1>{speaker.data.name}</h1>
  <p class="muted">{[speaker.data.title, speaker.data.company].filter(Boolean).join(" · ")}</p>

  {speaker.data.bio && <p>{speaker.data.bio}</p>}

  {speaker.data.links && Object.keys(speaker.data.links).length > 0 && (
    <ul class="links">
      {Object.entries(speaker.data.links).map(([platform, url]) => (
        <li><a href={url}>{platform}</a></li>
      ))}
    </ul>
  )}

  {episodes.length > 0 && (
    <section class="section">
      <h2>Episodes</h2>
      <div class="grid">
        {episodes.map((ep) => (
          <Card
            href={`${base}episodes/${ep.id}/`}
            title={ep.data.title}
            meta={ep.data.publishDate.toLocaleDateString()}
          />
        ))}
      </div>
    </section>
  )}

  <style>
    .links { list-style: none; padding: 0; display: flex; gap: 1rem; flex-wrap: wrap; }
    .section { margin-top: 2rem; }
  </style>
</BaseLayout>
