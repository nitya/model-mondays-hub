---
// site/src/pages/blog/[slug].astro
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const base = import.meta.env.BASE_URL;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.summary}>
  <a href={`${base}blog/`} class="muted">&larr; All posts</a>
  <article class="prose">
    <h1>{post.data.title}</h1>
    <p class="muted">
      {post.data.publishDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
    </p>
    <Content />
  </article>

  <style>
    .prose { max-width: 720px; line-height: 1.7; }
    .prose :global(h2) { margin-top: 2rem; }
    .prose :global(a) { color: var(--mm-link); }
  </style>
</BaseLayout>
