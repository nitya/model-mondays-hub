---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const models = (await getCollection("models")).sort((a, b) => a.data.name.localeCompare(b.data.name));

// Element symbols
const symbols: Record<string, string> = {
  "claude-sonnet": "Cl",
  "command-r-plus": "Co",
  "dall-e-3": "Da",
  "deepseek-r1": "Ds",
  "florence-2": "Fl",
  "gpt-4": "Gp",
  "gpt-4o": "Go",
  "llama-3": "Lm",
  "llama-4": "L4",
  "mai-1": "Ma",
  "mistral-large": "Mi",
  "o1": "O1",
  "o3": "O3",
  "phi-3": "Φ3",
  "phi-4": "Φ4",
  "whisper": "Wh",
};

// Category keys (colors are now CSS custom properties for dark mode support)
const categoryColors: Record<string, string> = {
  language: "var(--cat-language)",
  reasoning: "var(--cat-reasoning)",
  vision: "var(--cat-vision)",
  multimodal: "var(--cat-multimodal)",
  "image-generation": "var(--cat-image-generation)",
  "small-language": "var(--cat-small-language)",
  speech: "var(--cat-speech)",
  code: "var(--cat-code)",
  other: "var(--cat-other)",
};

const categoryLabels: Record<string, string> = {
  language: "Language",
  reasoning: "Reasoning",
  vision: "Vision",
  multimodal: "Multimodal",
  "image-generation": "Image Gen",
  "small-language": "Small Language",
  speech: "Speech",
  code: "Code",
  other: "Other",
};

// Periodic table layout:
// Columns = model families, rows = tiers (smaller/specialized → frontier)
// Row 1: Small/specialized (Phi, Florence, Whisper, DALL·E)
// Row 2: Mid-tier / focused (Command, Mistral, DeepSeek, MAI)
// Row 3: Frontier (GPT, Claude, Llama, o-series)
// Family columns (left to right): Microsoft | OpenAI | Meta | Anthropic | Cohere | Mistral | DeepSeek

interface TableCell {
  model: typeof models[0] | null;
  col: number;
  row: number;
}

// Define the grid: [row, col] placement per model ID
// Cols: 0=Microsoft, 1=OpenAI, 2=Meta, 3=Anthropic, 4=Cohere, 5=Mistral, 6=DeepSeek
const colLabels = ["Microsoft", "OpenAI", "Meta", "Anthropic", "Cohere", "Mistral AI", "DeepSeek"];
const rowLabels = ["Specialized", "Mid-tier", "Frontier"];

const placement: Record<string, [number, number]> = {
  // Row 0 (Specialized): small, single-purpose
  "phi-3":          [0, 0],
  "phi-4":          [0, 0], // stacked — we'll handle
  "florence-2":     [0, 0],
  "whisper":        [0, 1],
  "dall-e-3":       [0, 1],
  // Row 1 (Mid-tier): strong but not frontier
  "mai-1":          [1, 0],
  "o1":             [1, 1],
  "llama-3":        [1, 2],
  "command-r-plus": [1, 4],
  "mistral-large":  [1, 5],
  "deepseek-r1":    [1, 6],
  // Row 2 (Frontier): largest, most capable
  "gpt-4":          [2, 1],
  "gpt-4o":         [2, 1],
  "o3":             [2, 1],
  "llama-4":        [2, 2],
  "claude-sonnet":  [2, 3],
};

// Build grid cells - allow multiple models per cell
const grid: Map<string, typeof models[0][]> = new Map();
for (const m of models) {
  const pos = placement[m.id];
  if (!pos) continue;
  const key = `${pos[0]}-${pos[1]}`;
  if (!grid.has(key)) grid.set(key, []);
  grid.get(key)!.push(m);
}
---

<BaseLayout title="Models" description="AI models discussed on Model Mondays — periodic table view.">
  <div class="pt-page">
    <div class="pt-header">
      <h1>Periodic Table of AI Models</h1>
      <p class="muted">{models.length} models from {colLabels.length} providers — arranged by capability tier and family.</p>
    </div>

    <!-- Legend -->
    <div class="pt-legend">
      {Object.entries(categoryLabels).filter(([k]) => categoryColors[k]).map(([key, label]) => (
        <span class="pt-legend__item">
          <span class="pt-legend__swatch" style={`background: ${categoryColors[key]}`}></span>
          {label}
        </span>
      ))}
    </div>

    <!-- Table -->
    <div class="pt-table" style={`--cols: ${colLabels.length}`}>
      <!-- Column headers (providers) -->
      <div class="pt-table__header">
        {colLabels.map((label) => (
          <div class="pt-col-label">{label}</div>
        ))}
      </div>

      <!-- Rows -->
      {rowLabels.map((rowLabel, rowIdx) => (
        <div class="pt-table__row">
          <div class="pt-row-label">{rowLabel}</div>
          <div class="pt-table__cells">
            {colLabels.map((_, colIdx) => {
              const key = `${rowIdx}-${colIdx}`;
              const cellModels = grid.get(key) || [];
              return (
                <div class="pt-cell">
                  {cellModels.map((m) => (
                    <a
                      class="pt-element"
                      href={m.data.catalogUrl || m.data.providerUrl || "#"}
                      target="_blank"
                      rel="noopener"
                      title={`${m.data.name} (${m.data.provider}) — ${categoryLabels[m.data.category ?? "other"]}`}
                      style={`--el-color: ${categoryColors[m.data.category ?? "other"]}`}
                    >
                      <span class="pt-element__number">{m.data.episodes.length || "—"}</span>
                      <span class="pt-element__symbol">{symbols[m.id] ?? m.id.slice(0,2).toUpperCase()}</span>
                      <span class="pt-element__name">{m.data.name}</span>
                      {m.data.openSource && <span class="pt-element__os">OS</span>}
                    </a>
                  ))}
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <!-- Reading guide -->
    <div class="pt-guide">
      <h2>How to read</h2>
      <div class="pt-guide__grid">
        <div class="pt-guide__item">
          <div class="pt-element pt-element--demo" style="--el-color: var(--cat-language)">
            <span class="pt-element__number">3</span>
            <span class="pt-element__symbol">Gp</span>
            <span class="pt-element__name">GPT-4</span>
            <span class="pt-element__os">OS</span>
          </div>
        </div>
        <div class="pt-guide__labels">
          <p><strong>Top-left number:</strong> Episodes featuring this model</p>
          <p><strong>Large symbol:</strong> Model abbreviation</p>
          <p><strong>Bottom name:</strong> Full model name</p>
          <p><strong>"OS" badge:</strong> Open source model</p>
          <p><strong>Border color:</strong> Category (language, reasoning, etc.)</p>
          <p><strong>Rows:</strong> Specialized → Mid-tier → Frontier (top to bottom)</p>
          <p><strong>Columns:</strong> Provider / model family</p>
        </div>
      </div>
    </div>
  </div>

  <style>
    /* Category colors — light mode */
    :root, [data-theme="light"] {
      --cat-language: #5b21b6;
      --cat-reasoning: #0d9488;
      --cat-vision: #b45309;
      --cat-multimodal: #7c3aed;
      --cat-image-generation: #db2777;
      --cat-small-language: #166534;
      --cat-speech: #0369a1;
      --cat-code: #4338ca;
      --cat-other: #6b7280;
    }
    /* Brighter variants for dark mode */
    [data-theme="dark"] {
      --cat-language: #c4b5fd;
      --cat-reasoning: #5eead4;
      --cat-vision: #fbbf24;
      --cat-multimodal: #a78bfa;
      --cat-image-generation: #f472b6;
      --cat-small-language: #4ade80;
      --cat-speech: #38bdf8;
      --cat-code: #818cf8;
      --cat-other: #9ca3af;
    }
    @media (prefers-color-scheme: dark) {
      :root:not([data-theme="light"]) {
        --cat-language: #c4b5fd;
        --cat-reasoning: #5eead4;
        --cat-vision: #fbbf24;
        --cat-multimodal: #a78bfa;
        --cat-image-generation: #f472b6;
        --cat-small-language: #4ade80;
        --cat-speech: #38bdf8;
        --cat-code: #818cf8;
        --cat-other: #9ca3af;
      }
    }

    .pt-page { max-width: 1000px; }
    .pt-header { margin-bottom: 1.5rem; }
    .pt-header h1 { margin-bottom: 0.4rem; }

    .pt-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 2rem;
      padding: 0.75rem 1rem;
      background: var(--mm-bg-elevated);
      border: 1px solid var(--mm-border);
      border-radius: var(--mm-radius);
    }
    .pt-legend__item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--mm-text-muted);
    }
    .pt-legend__swatch {
      width: 12px;
      height: 12px;
      border-radius: 3px;
    }

    .pt-table {
      margin-bottom: 3rem;
    }
    .pt-table__header {
      display: grid;
      grid-template-columns: repeat(var(--cols), 1fr);
      gap: 0.5rem;
      margin-left: 80px;
      margin-bottom: 0.75rem;
    }
    .pt-col-label {
      text-align: center;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--mm-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .pt-table__row {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 0.75rem;
      align-items: flex-start;
    }
    .pt-row-label {
      width: 80px;
      flex-shrink: 0;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--mm-text-muted);
      text-transform: uppercase;
      padding-top: 1.5rem;
      text-align: right;
      padding-right: 0.5rem;
    }
    .pt-table__cells {
      display: grid;
      grid-template-columns: repeat(var(--cols), 1fr);
      gap: 0.5rem;
      flex: 1;
    }
    .pt-cell {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      min-height: 90px;
    }

    .pt-element {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 0.5rem 0.4rem;
      border-radius: 10px;
      border: 2.5px solid var(--el-color);
      background: var(--mm-bg-elevated);
      box-shadow: var(--mm-shadow-sm);
      text-decoration: none;
      color: var(--mm-text);
      position: relative;
      transition: transform 0.2s, box-shadow 0.2s;
      min-width: 0;
    }
    .pt-element:hover {
      transform: scale(1.08);
      box-shadow: 0 4px 16px color-mix(in srgb, var(--el-color) 30%, transparent);
      text-decoration: none;
      z-index: 5;
    }
    .pt-element__number {
      position: absolute;
      top: 4px;
      left: 6px;
      font-size: 0.6rem;
      font-weight: 700;
      color: var(--el-color);
    }
    .pt-element__symbol {
      font-family: var(--mm-font-display);
      font-size: 1.5rem;
      font-weight: 700;
      line-height: 1;
      color: var(--el-color);
    }
    .pt-element__name {
      font-size: 0.6rem;
      font-weight: 500;
      text-align: center;
      line-height: 1.2;
      color: var(--mm-text-muted);
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .pt-element__os {
      position: absolute;
      top: 4px;
      right: 5px;
      font-size: 0.5rem;
      font-weight: 800;
      color: var(--mm-green, #166534);
      background: var(--mm-green-soft, #dcfce7);
      padding: 0 3px;
      border-radius: 3px;
      line-height: 1.4;
    }

    .pt-guide {
      padding: 1.5rem;
      background: var(--mm-accent-soft);
      border-radius: var(--mm-radius-lg);
      border: 1px solid var(--mm-border);
    }
    .pt-guide h2 {
      margin: 0 0 1rem;
      font-size: 1.1rem;
    }
    .pt-guide__grid {
      display: flex;
      gap: 2rem;
      align-items: flex-start;
      flex-wrap: wrap;
    }
    .pt-guide__item {
      flex-shrink: 0;
    }
    .pt-element--demo {
      width: 90px;
      height: 90px;
      font-size: 1rem;
    }
    .pt-guide__labels p {
      margin: 0.3rem 0;
      font-size: 0.85rem;
    }

    @media (max-width: 700px) {
      .pt-table__header { margin-left: 0; }
      .pt-table__row { flex-direction: column; }
      .pt-row-label { width: auto; text-align: left; padding-top: 0.5rem; }
      .pt-table__cells {
        grid-template-columns: repeat(3, 1fr);
      }
      .pt-col-label { font-size: 0.65rem; }
    }
  </style>
</BaseLayout>
