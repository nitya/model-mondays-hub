---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const models = (await getCollection("models")).sort((a, b) => a.data.name.localeCompare(b.data.name));

// Group by provider for the sidebar/filter
const providers = [...new Set(models.map((m) => m.data.provider))].sort();
const categories = [...new Set(models.map((m) => m.data.category ?? "other"))].sort();

const categoryEmoji: Record<string, string> = {
  language: "💬",
  reasoning: "🧠",
  vision: "👁️",
  multimodal: "🎭",
  "image-generation": "🎨",
  "small-language": "🔬",
  speech: "🎙️",
  code: "💻",
  forecasting: "📈",
  embedding: "📐",
  other: "🔧",
};

const categoryLabels: Record<string, string> = {
  language: "Language",
  reasoning: "Reasoning",
  vision: "Vision",
  multimodal: "Multimodal",
  "image-generation": "Image Gen",
  "small-language": "Small Language",
  speech: "Speech",
  code: "Code",
  forecasting: "Forecasting",
  embedding: "Embedding",
  other: "Other",
};
---

<BaseLayout title="Models" description="AI models discussed on Model Mondays.">
  <div class="models-page">
    <div class="models-header">
      <h1>Model Catalog</h1>
      <p class="muted">{models.length} AI models from {providers.length} providers — all available on Azure AI Foundry.</p>
    </div>

    <!-- Quick category jump pills -->
    <nav class="models-nav" aria-label="Filter by category">
      <button class="models-nav__btn models-nav__btn--active" data-filter="all">All ({models.length})</button>
      {categories.map((cat) => (
        <button class="models-nav__btn" data-filter={cat}>
          {categoryEmoji[cat] ?? "🔧"} {categoryLabels[cat] ?? cat} ({models.filter(m => (m.data.category ?? "other") === cat).length})
        </button>
      ))}
    </nav>

    <!-- Model list -->
    <div class="models-list">
      {models.map((m) => (
        <article class="model-row" data-category={m.data.category ?? "other"} data-provider={m.data.provider}>
          <div class="model-row__icon">
            <span class="model-row__emoji">{categoryEmoji[m.data.category ?? "other"] ?? "🔧"}</span>
          </div>
          <div class="model-row__body">
            <div class="model-row__top">
              <h3 class="model-row__name">{m.data.name}</h3>
              <div class="model-row__badges">
                {m.data.openSource && <span class="pill pill--model">Open Source</span>}
                {m.data.status === "new" && <span class="pill pill--model">New</span>}
                {m.data.status === "deprecated" && <span class="pill pill--partner">Deprecated</span>}
              </div>
            </div>
            <div class="model-row__provider">{m.data.provider} · {categoryLabels[m.data.category ?? "other"] ?? m.data.category}</div>
            {m.data.description && <p class="model-row__desc">{m.data.description}</p>}
            <div class="model-row__footer">
              <div class="model-row__links">
                {m.data.catalogUrl && <a href={m.data.catalogUrl} target="_blank" rel="noopener" class="model-row__cta">Azure Catalog ↗</a>}
                {m.data.providerUrl && <a href={m.data.providerUrl} target="_blank" rel="noopener">Provider</a>}
                {m.data.learnUrl && <a href={m.data.learnUrl} target="_blank" rel="noopener">Learn</a>}
              </div>
              {m.data.episodes.length > 0 && (
                <div class="model-row__episodes">
                  <span>Featured in {m.data.episodes.length} episode{m.data.episodes.length > 1 ? "s" : ""}</span>
                </div>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>(".models-nav__btn");
    const rows = document.querySelectorAll<HTMLElement>(".model-row");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        buttons.forEach((b) => b.classList.remove("models-nav__btn--active"));
        btn.classList.add("models-nav__btn--active");
        const filter = btn.dataset.filter;
        rows.forEach((row) => {
          row.style.display = filter === "all" || row.dataset.category === filter ? "" : "none";
        });
      });
    });
  </script>

  <style>
    .models-page {
      max-width: 900px;
    }
    .models-header {
      margin-bottom: 1.5rem;
    }
    .models-header h1 {
      margin-bottom: 0.5rem;
    }
    .models-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--mm-border);
    }
    .models-nav__btn {
      padding: 0.4rem 0.9rem;
      border-radius: var(--mm-radius-pill);
      border: 1px solid var(--mm-border);
      background: var(--mm-bg-elevated);
      font-size: 0.82rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s ease;
      color: var(--mm-text-muted);
    }
    .models-nav__btn:hover {
      border-color: var(--mm-accent);
      color: var(--mm-accent);
    }
    .models-nav__btn--active {
      background: var(--mm-accent);
      color: var(--mm-accent-contrast);
      border-color: var(--mm-accent);
    }

    .models-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .model-row {
      display: flex;
      gap: 1rem;
      padding: 1.25rem;
      background: var(--mm-bg-elevated);
      border: 1px solid var(--mm-border);
      border-radius: var(--mm-radius);
      box-shadow: var(--mm-shadow-sm);
      transition: box-shadow 0.2s, transform 0.15s;
    }
    .model-row:hover {
      box-shadow: var(--mm-shadow);
      transform: translateX(4px);
    }

    .model-row__icon {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: var(--mm-accent-soft);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
    }

    .model-row__body {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .model-row__top {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-wrap: wrap;
    }
    .model-row__name {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 700;
      font-family: var(--mm-font-display);
    }
    .model-row__badges {
      display: flex;
      gap: 0.4rem;
    }
    .model-row__provider {
      font-size: 0.82rem;
      color: var(--mm-text-muted);
      font-weight: 500;
    }
    .model-row__desc {
      margin: 0.2rem 0 0;
      font-size: 0.88rem;
      line-height: 1.5;
      color: var(--mm-text-muted);
    }
    .model-row__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 0.5rem;
      flex-wrap: wrap;
    }
    .model-row__links {
      display: flex;
      gap: 1rem;
      font-size: 0.82rem;
      font-weight: 500;
    }
    .model-row__cta {
      font-weight: 700;
      color: var(--mm-accent);
    }
    .model-row__episodes {
      font-size: 0.78rem;
      color: var(--mm-teal, var(--mm-accent-2));
      font-weight: 600;
    }

    @media (max-width: 600px) {
      .model-row__icon { display: none; }
    }
  </style>
</BaseLayout>
