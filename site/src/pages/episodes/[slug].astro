---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagPill from "../../components/TagPill.astro";

export async function getStaticPaths() {
  const episodes = await getCollection("episodes");
  return episodes.map((ep) => ({ params: { slug: ep.id }, props: { ep } }));
}

const { ep } = Astro.props;
const base = import.meta.env.BASE_URL;
const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
const formatDuration = (seconds: number) => {
  const hours = Math.floor(seconds / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);
  const remainingSeconds = seconds % 60;

  if (hours > 0) {
    return `${hours}h ${minutes.toString().padStart(2, "0")}m`;
  }
  if (minutes > 0) {
    return `${minutes}m ${remainingSeconds.toString().padStart(2, "0")}s`;
  }
  return `${remainingSeconds}s`;
};
const getEpisodeLabel = (seasonNumber: number | undefined, episodeId: string) => {
  const match = episodeId.match(/s\d+-e(\d+)/i);
  const episodeNumber = match ? Number(match[1]) : undefined;
  if (seasonNumber == null || episodeNumber == null) return undefined;
  return `S${seasonNumber} · E${episodeNumber}`;
};

const allSpeakers = await getCollection("speakers");
const speakerById = new Map(allSpeakers.map((s) => [s.id, s.data]));
const speakers = ep.data.speakers
  .map((id) => ({ id, data: speakerById.get(id) }))
  .filter((s) => Boolean(s.data)) as { id: string; data: NonNullable<ReturnType<typeof speakerById.get>> }[];

const allTags = await getCollection("tags");
const tagById = new Map(allTags.map((t) => [t.id, t.data]));
const tags = ep.data.tags
  .map((id) => tagById.get(id))
  .filter((t) => Boolean(t)) as NonNullable<ReturnType<typeof tagById.get>>[];

const season = await getEntry("seasons", ep.data.season);
const seasonLabel = getEpisodeLabel(season?.data.number, ep.id);
const infoBadges = [
  seasonLabel,
  formatDate(ep.data.publishDate),
  ep.data.duration != null ? `⏱ ${formatDuration(ep.data.duration)}` : undefined,
].filter((item) => Boolean(item)) as string[];
const metrics = [
  ep.data.metrics?.views != null ? `👁 ${ep.data.metrics.views.toLocaleString("en-US")}` : undefined,
  ep.data.metrics?.likes != null ? `👍 ${ep.data.metrics.likes.toLocaleString("en-US")}` : undefined,
  ep.data.metrics?.comments != null ? `💬 ${ep.data.metrics.comments.toLocaleString("en-US")}` : undefined,
].filter((item) => Boolean(item)) as string[];

const allTranscripts = await getCollection("transcripts");
const transcriptIds = new Set(allTranscripts.map((entry) => entry.id));
let transcript: Awaited<ReturnType<typeof render>> | null = null;
if (ep.data.transcriptPath) {
  const transcriptId = ep.data.transcriptPath.split("/").pop()?.replace(/\.md$/, "");
  if (transcriptId && transcriptIds.has(transcriptId)) {
    const entry = await getEntry("transcripts", transcriptId);
    if (entry) transcript = await render(entry);
  }
}
---

<BaseLayout title={ep.data.title} description={ep.data.description}>
  <a href={`${base}episodes/`} class="muted">&larr; All episodes</a>
  <h1>{ep.data.title}</h1>

  <div class="episode-info-row">
    {infoBadges.map((badge) => <span class="meta-badge">{badge}</span>)}
    {season && <span class="muted episode-season-title">{season.data.title}</span>}
    {ep.data.status !== "published" && <span class="pill pill--technology">Upcoming</span>}
  </div>

  {tags.length > 0 && (
    <div class="tag-row">
      {tags.map((t) => <TagPill label={t.label} category={t.category} />)}
    </div>
  )}

  {ep.data.youtubeVideoId && (
    <div class="video-embed">
      <iframe
        src={`https://www.youtube-nocookie.com/embed/${ep.data.youtubeVideoId}`}
        title={ep.data.title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  )}

  {ep.data.description && (
    <section class="section">
      <h2>Description</h2>
      <p>{ep.data.description}</p>
    </section>
  )}

  {speakers.length > 0 && (
    <section class="section">
      <h2>Speakers</h2>
      <ul class="speaker-list">
        {speakers.map((s) => (
          <li>
            <a href={`${base}speakers/${s.id}/`}>{s.data.name}</a>
            {s.data.company && <span class="muted"> — {s.data.company}</span>}
          </li>
        ))}
      </ul>
    </section>
  )}

  {metrics.length > 0 && (
    <section class="section">
      <h2>Metrics</h2>
      <div class="metric-badge-row">
        {metrics.map((metric) => <span class="metric-badge">{metric}</span>)}
      </div>
    </section>
  )}

  {ep.data.resources && ep.data.resources.length > 0 && (
    <section class="section resources-section">
      <h2>📚 Related Resources</h2>
      <ul class="resources-list">
        {ep.data.resources.map((r) => (
          <li>
            <a href={r.url} target="_blank" rel="noopener noreferrer">
              {r.title}
            </a>
            <span class="resource-type">{r.type}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  {ep.data.summary && (
    <section class="section">
      <h2>Episode Summary</h2>
      {ep.data.summary.highlights && ep.data.summary.highlights.length > 0 && (
        <div class="summary-segment">
          <h3>🔦 Highlights</h3>
          <ul>{ep.data.summary.highlights.map((h) => <li>{h}</li>)}</ul>
        </div>
      )}
      {ep.data.summary.techSpotlights && ep.data.summary.techSpotlights.length > 0 && (
        <div class="summary-segment">
          <h3>🔬 Tech Spotlights</h3>
          <ul>{ep.data.summary.techSpotlights.map((h) => <li>{h}</li>)}</ul>
        </div>
      )}
      {ep.data.summary.customerStories && ep.data.summary.customerStories.length > 0 && (
        <div class="summary-segment">
          <h3>💼 Customer Stories</h3>
          <ul>{ep.data.summary.customerStories.map((h) => <li>{h}</li>)}</ul>
        </div>
      )}
      {ep.data.summary.partnerSpotlights && ep.data.summary.partnerSpotlights.length > 0 && (
        <div class="summary-segment">
          <h3>🤝 Partner Spotlights</h3>
          <ul>{ep.data.summary.partnerSpotlights.map((h) => <li>{h}</li>)}</ul>
        </div>
      )}
    </section>
  )}

  {ep.data.chapters && ep.data.chapters.length > 0 && (
    <section class="section">
      <h2>Chapters</h2>
      <div class="chapter-grid">
        {ep.data.chapters.map((c) => {
          const parts = c.time.split(":").map(Number);
          const totalSeconds = parts.length === 3
            ? parts[0] * 3600 + parts[1] * 60 + parts[2]
            : parts[0] * 60 + parts[1];
          const ytUrl = ep.data.youtubeVideoId
            ? `https://www.youtube.com/watch?v=${ep.data.youtubeVideoId}&t=${totalSeconds}s`
            : undefined;
          return (
            <a class="chapter-chip" href={ytUrl} target="_blank" rel="noopener noreferrer" title={`Jump to ${c.time}`}>
              <span class="chapter-time">{c.time}</span>
              <span class="chapter-label">{c.label}</span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {transcript && (
    <section class="section">
      <h2>Transcript</h2>
      <details>
        <summary>Show full transcript</summary>
        <div class="transcript">
          <transcript.Content />
        </div>
      </details>
    </section>
  )}

  <style>
    .episode-info-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .episode-season-title {
      font-size: 0.95rem;
    }
    .tag-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 1rem 0; }
    .video-embed {
      position: relative;
      padding-bottom: 56.25%;
      height: 0;
      overflow: hidden;
      border-radius: var(--mm-radius);
      margin: 1.5rem 0;
    }
    .video-embed iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
    }
    .section { margin-top: 2rem; }
    .speaker-list { list-style: none; padding: 0; }
    .speaker-list li { padding: 0.3rem 0; }
    .chapter-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .chapter-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.3rem 0.7rem;
      background: var(--mm-bg-elevated);
      border: 1px solid var(--mm-border);
      border-radius: var(--mm-radius);
      text-decoration: none;
      color: inherit;
      font-size: 0.85rem;
      transition: border-color 0.2s, background 0.2s;
    }
    .chapter-chip:hover {
      border-color: var(--mm-accent);
      background: color-mix(in srgb, var(--mm-accent) 10%, transparent);
    }
    .chapter-time {
      font-family: var(--mm-font-mono);
      color: var(--mm-accent);
      font-weight: 600;
      font-size: 0.8rem;
    }
    .chapter-label { font-size: 0.85rem; }
    .resources-section {
      background: var(--mm-bg-elevated);
      border: 1px solid var(--mm-border);
      border-radius: var(--mm-radius);
      padding: 1.25rem;
    }
    .resources-list { list-style: none; padding: 0; }
    .resources-list li {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0;
    }
    .resources-list a { font-weight: 500; }
    .resource-type {
      font-size: 0.75rem;
      padding: 0.15rem 0.5rem;
      background: var(--mm-border);
      border-radius: 9999px;
      text-transform: capitalize;
    }
    .summary-segment { margin-bottom: 1rem; }
    .summary-segment h3 { font-size: 1rem; margin-bottom: 0.3rem; }
    .summary-segment ul { padding-left: 1.2rem; margin: 0; }
    .summary-segment li { padding: 0.2rem 0; font-size: 0.95rem; }
    .transcript {
      max-height: 480px;
      overflow-y: auto;
      padding: 1rem;
      margin-top: 0.75rem;
      background: var(--mm-bg-elevated);
      border: 1px solid var(--mm-border);
      border-radius: var(--mm-radius);
      font-size: 0.9rem;
      line-height: 1.6;
    }
  </style>
</BaseLayout>
