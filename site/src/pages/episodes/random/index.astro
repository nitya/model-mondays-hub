---
// site/src/pages/episodes/random/index.astro
// Client-side random episode picker — shuffles on every page load.
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const episodes = (await getCollection("episodes")).filter(
  (e) => e.data.status === "published" && e.data.youtubeVideoId
);

const episodeList = episodes.map((e) => ({
  id: e.id,
  videoId: e.data.youtubeVideoId,
  title: e.data.title,
}));
---

<BaseLayout title="Random Episode" description="Revisit a random Model Mondays episode.">
  <section class="random-episode">
    <h1>🎲 Random Episode</h1>
    <p class="muted">A random pick from the archives — refresh or shuffle for another!</p>

    <div class="random-episode__player" id="player-container">
      <iframe
        id="video-frame"
        width="100%"
        height="100%"
        src=""
        title="Loading..."
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>

    <div class="random-episode__meta">
      <h2 id="episode-title">Loading...</h2>
      <div class="random-episode__actions">
        <a id="episode-link" class="button" href="#">View full episode page</a>
        <button class="button button--ghost" id="shuffle-btn">🎲 Shuffle another</button>
      </div>
    </div>
  </section>

  <script define:vars={{ episodeList, base }}>
    function loadRandom() {
      const pick = episodeList[Math.floor(Math.random() * episodeList.length)];
      const frame = document.getElementById("video-frame");
      const titleEl = document.getElementById("episode-title");
      const linkEl = document.getElementById("episode-link");
      frame.src = `https://www.youtube.com/embed/${pick.videoId}?rel=0`;
      frame.title = pick.title;
      titleEl.textContent = pick.title;
      linkEl.href = `${base}episodes/${pick.id}/`;
    }

    // Pick on page load (client-side, truly random each visit)
    loadRandom();

    document.getElementById("shuffle-btn").addEventListener("click", () => {
      loadRandom();
    });
  </script>

  <style>
    .random-episode {
      max-width: 900px;
      margin: 0 auto;
    }
    .random-episode__player {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: var(--mm-radius-lg);
      overflow: hidden;
      box-shadow: var(--mm-shadow-lg);
      margin: 1.5rem 0;
    }
    .random-episode__player iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }
    .random-episode__meta {
      text-align: center;
    }
    .random-episode__meta h2 {
      margin: 0.5rem 0 1rem;
    }
    .random-episode__actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
  </style>
</BaseLayout>
