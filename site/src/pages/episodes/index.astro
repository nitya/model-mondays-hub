---
// site/src/pages/episodes/index.astro
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import Gallery from "../../components/Gallery.astro";

const base = import.meta.env.BASE_URL;
const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
const getEpisodeLabel = (seasonNumber: number | undefined, episodeId: string) => {
  const match = episodeId.match(/s\d+-e(\d+)/i);
  const episodeNumber = match ? Number(match[1]) : undefined;
  if (seasonNumber == null || episodeNumber == null) return undefined;
  return `S${seasonNumber} · E${episodeNumber}`;
};

const episodes = (await getCollection("episodes")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const allTags = await getCollection("tags");
const allSeasons = await getCollection("seasons");
const tagById = new Map(allTags.map((t) => [t.id, t.data]));
const seasonById = new Map(allSeasons.map((season) => [season.id, season.data]));

const tagOptions = allTags
  .map((t) => ({ id: t.id, label: t.data.label, category: t.data.category }))
  .sort((a, b) => a.label.localeCompare(b.label));

const episodeCards = episodes.map((ep) => {
  const tags = ep.data.tags
    .map((id) => tagById.get(id))
    .filter((t) => Boolean(t))
    .map((t) => ({ label: t!.label, category: t!.category }));
  const seasonLabel = getEpisodeLabel(seasonById.get(ep.data.season)?.number, ep.id);
  return { ep, tags, seasonLabel };
});
---

<BaseLayout title="Episodes" description="All Model Mondays episodes.">
  <div class="page-header">
    <h1>Episodes</h1>
    <a href={`${base}episodes/timeline/`} class="button">📈 Timeline</a>
  </div>
  <p class="muted">{episodes.length} episode{episodes.length === 1 ? "" : "s"} — published and upcoming.</p>

  <Gallery tagOptions={tagOptions} gridId="episode-grid">
    <div class="grid" id="episode-grid">
      {episodeCards.map(({ ep, tags, seasonLabel }) => (
        <Card
          href={`${base}episodes/${ep.id}/`}
          title={ep.data.title}
          subtitle={ep.data.status !== "published" ? "Upcoming" : undefined}
          publishDate={formatDate(ep.data.publishDate)}
          videoId={ep.data.youtubeVideoId}
          seasonLabel={seasonLabel}
          views={ep.data.metrics?.views}
          tags={tags}
          searchText={`${ep.data.title} ${ep.data.description ?? ""}`.toLowerCase()}
          sortDate={ep.data.publishDate.toISOString()}
          sortTitle={ep.data.title.toLowerCase()}
        />
      ))}
    </div>
  </Gallery>
</BaseLayout>
