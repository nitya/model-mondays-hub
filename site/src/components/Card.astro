---
// site/src/components/Card.astro
// Generic card used by the episode and speaker galleries.
import TagPill from "./TagPill.astro";

interface Props {
  href: string;
  title: string;
  subtitle?: string;
  meta?: string;
  publishDate?: string;
  videoId?: string;
  seasonLabel?: string;
  views?: number;
  tags?: { label: string; category?: "model" | "technology" | "partner" }[];
  searchText?: string; // lowercase text used by client-side search filtering
  sortDate?: string; // ISO date used by client-side sort
  sortTitle?: string;
}

const {
  href,
  title,
  subtitle,
  meta,
  publishDate,
  videoId,
  seasonLabel,
  views,
  tags = [],
  searchText,
  sortDate,
  sortTitle,
} = Astro.props;

const thumbnailUrl = videoId ? `https://i.ytimg.com/vi/${videoId}/mqdefault.jpg` : undefined;
const isUpcoming = !videoId;
const bannerUrl = isUpcoming
  ? `${import.meta.env.BASE_URL}images/model-mondays-banner.png`
  : undefined;
const compactNumber = new Intl.NumberFormat("en-US", {
  notation: "compact",
  maximumFractionDigits: 1,
});
const viewLabel = views != null ? `${compactNumber.format(views)} views` : undefined;
const metaItems = [publishDate, viewLabel, meta].filter((item) => Boolean(item)) as string[];
---

<a
  class="mm-card card"
  href={href}
  data-search={searchText ?? title.toLowerCase()}
  data-date={sortDate ?? ""}
  data-title={sortTitle ?? title.toLowerCase()}
  data-tags={tags.map((t) => t.label.toLowerCase()).join("|")}
>
  {thumbnailUrl && (
    <div class="mm-card__media">
      <img src={thumbnailUrl} alt="" loading="lazy" />
    </div>
  )}
  {!thumbnailUrl && (
    <div class="mm-card__media mm-card__media--placeholder">
      <img src={bannerUrl} alt="Model Mondays" loading="lazy" />
      <span class="mm-card__new-badge">NEW</span>
    </div>
  )}

  <div class="mm-card__content">
    {seasonLabel && (
      <div class="mm-card__header-row">
        <span class="pill mm-card__season">{seasonLabel}</span>
      </div>
    )}

    <h3 class="mm-card__title">{title}</h3>
    {subtitle && <p class="mm-card__subtitle muted">{subtitle}</p>}

    {metaItems.length > 0 && (
      <div class="mm-card__meta muted">
        {metaItems.map((item) => <span class="mm-card__meta-item">{item}</span>)}
      </div>
    )}

    {tags.length > 0 && (
      <div class="mm-card__tags">
        {tags.map((t) => <TagPill label={t.label} category={t.category} />)}
      </div>
    )}
  </div>
</a>

<style>
  .mm-card {
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow: hidden;
    padding: 0;
    border-radius: var(--mm-radius-lg);
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease;
  }
  .mm-card:hover {
    text-decoration: none;
    transform: translateY(-4px) scale(1.01);
    box-shadow: var(--mm-shadow-lg);
  }
  .mm-card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--mm-accent-soft);
    overflow: hidden;
  }
  .mm-card__media--placeholder {
    background: linear-gradient(135deg, var(--mm-accent-soft) 0%, color-mix(in srgb, var(--mm-accent-2) 15%, transparent) 100%);
  }
  .mm-card__media--placeholder img {
    opacity: 0.85;
    transition: opacity 0.2s;
  }
  .mm-card:hover .mm-card__media--placeholder img { opacity: 1; }
  .mm-card__new-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    padding: 0.25em 0.7em;
    border-radius: var(--mm-radius-pill);
    background: var(--mm-accent-gradient);
    color: var(--mm-accent-contrast);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: 0 2px 8px rgba(124, 58, 237, 0.3);
  }
  .mm-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .mm-card:hover .mm-card__media img {
    transform: scale(1.03);
  }
  .mm-card__content {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1rem 1.2rem 1.2rem;
  }
  .mm-card__header-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .mm-card__season {
    width: fit-content;
    font-size: 0.72rem;
    background: var(--mm-accent-gradient);
    color: var(--mm-accent-contrast);
    border: none;
  }
  .mm-card__title {
    margin: 0;
    font-family: var(--mm-font-display);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
  }
  .mm-card__subtitle {
    margin: -0.2rem 0 0;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .mm-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
    font-size: 0.82rem;
  }
  .mm-card__meta-item {
    position: relative;
  }
  .mm-card__meta-item:not(:first-child)::before {
    content: "·";
    position: absolute;
    left: -0.55rem;
    color: var(--mm-border);
    font-weight: 700;
  }
  .mm-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.2rem;
  }
</style>
