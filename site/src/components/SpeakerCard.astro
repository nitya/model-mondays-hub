---
// site/src/components/SpeakerCard.astro
// Square profile card for speakers with avatar image support.
interface Props {
  href: string;
  name: string;
  title?: string;
  company?: string;
  role?: string;
  avatar?: string;
  linkedin?: string;
  github?: string;
  searchText?: string;
  sortTitle?: string;
}

const { href, name, title, company, role, avatar, linkedin, github, searchText, sortTitle } = Astro.props;
const initials = name.split(" ").map((n) => n[0]).join("").slice(0, 2);
---

<a
  class={`speaker-card card ${role === "host" ? "speaker-card--host" : role === "producer" ? "speaker-card--producer" : ""}`}
  href={href}
  data-search={searchText ?? name.toLowerCase()}
  data-title={sortTitle ?? name.toLowerCase()}
  data-tags=""
  data-date=""
>
  <div class="speaker-card__avatar">
    {avatar ? (
      <img src={avatar} alt={name} loading="lazy" />
    ) : (
      <span class="speaker-card__initials">{initials}</span>
    )}
  </div>
  <div class="speaker-card__info">
    <h3 class="speaker-card__name">{name}</h3>
    {title && <p class="speaker-card__title muted">{title}</p>}
    {company && <p class="speaker-card__company">{company}</p>}
    {(linkedin || github) && (
      <div class="speaker-card__links">
        {linkedin && (
          <a href={linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${name} on LinkedIn`} class="speaker-card__social" onclick="event.stopPropagation()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        )}
        {github && (
          <a href={github} target="_blank" rel="noopener noreferrer" aria-label={`${name} on GitHub`} class="speaker-card__social" onclick="event.stopPropagation()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
        )}
      </div>
    )}
  </div>
</a>

<style>
  .speaker-card {
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
    overflow: hidden;
    padding: 0;
    border-radius: var(--mm-radius-lg);
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease;
  }
  .speaker-card:hover {
    text-decoration: none;
    transform: translateY(-4px) scale(1.02);
    box-shadow: var(--mm-shadow-lg);
  }
  .speaker-card__avatar {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--mm-accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  /* Host: gold ring around avatar */
  .speaker-card--host .speaker-card__avatar {
    box-shadow: inset 0 0 0 4px var(--mm-gold, #b45309);
  }
  /* Producer: teal ring */
  .speaker-card--producer .speaker-card__avatar {
    box-shadow: inset 0 0 0 4px var(--mm-teal, #0d9488);
  }
  .speaker-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .speaker-card:hover .speaker-card__avatar img {
    transform: scale(1.05);
  }
  .speaker-card__initials {
    font-family: var(--mm-font-display);
    font-size: 2.5rem;
    font-weight: 700;
    background: var(--mm-accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    opacity: 0.7;
  }
  .speaker-card__info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 1rem 1rem 1.2rem;
  }
  .speaker-card__name {
    margin: 0;
    font-family: var(--mm-font-display);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .speaker-card__title {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.4;
  }
  .speaker-card__company {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--mm-accent);
  }
  .speaker-card__links {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.4rem;
  }
  .speaker-card__social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--mm-accent-soft);
    color: var(--mm-accent);
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .speaker-card__social:hover {
    background: var(--mm-accent);
    color: var(--mm-accent-contrast, #fff);
    transform: scale(1.15);
  }
</style>
