---
// site/src/components/Banner.astro
// Top-of-page announcement banner. Configured via data/site/banner.yaml.
interface Props {
  text: string;
  link?: string;
  linkText?: string;
  dismissable?: boolean;
  theme?: "accent" | "gold" | "teal";
}

const { text, link, linkText = "Learn more", dismissable = true, theme = "accent" } = Astro.props;
---

<div class={`banner banner--${theme}`} id="site-banner" role="banner">
  <div class="banner__content">
    <span class="banner__text">{text}</span>
    {link && (
      <a class="banner__link" href={link} target="_blank" rel="noopener noreferrer">
        {linkText}
      </a>
    )}
  </div>
  {dismissable && (
    <button class="banner__dismiss" aria-label="Dismiss banner" id="banner-dismiss">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  )}
</div>

<script>
  const banner = document.getElementById("site-banner");
  const dismiss = document.getElementById("banner-dismiss");
  const STORAGE_KEY = "mm-banner-dismissed";

  if (banner && localStorage.getItem(STORAGE_KEY) === banner.querySelector(".banner__text")?.textContent) {
    banner.style.display = "none";
  }

  dismiss?.addEventListener("click", () => {
    if (banner) {
      banner.style.display = "none";
      const text = banner.querySelector(".banner__text")?.textContent || "";
      localStorage.setItem(STORAGE_KEY, text);
    }
  });
</script>

<style>
  .banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.6rem 1.5rem;
    font-size: 0.88rem;
    font-weight: 600;
    text-align: center;
    position: relative;
  }
  .banner--accent {
    background: var(--mm-accent-gradient);
    color: var(--mm-accent-contrast);
  }
  .banner--gold {
    background: linear-gradient(135deg, #b45309 0%, #f59e0b 100%);
    color: #fff;
  }
  .banner--teal {
    background: linear-gradient(135deg, #0d9488 0%, #5eead4 100%);
    color: #042f2e;
  }
  .banner__content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .banner__link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 700;
    opacity: 0.95;
  }
  .banner__link:hover {
    opacity: 1;
    text-decoration-thickness: 2px;
  }
  .banner__dismiss {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    opacity: 0.7;
    padding: 0.25rem;
    border-radius: 4px;
    transition: opacity 0.15s;
  }
  .banner__dismiss:hover {
    opacity: 1;
    background: rgba(255,255,255,0.15);
  }
</style>
